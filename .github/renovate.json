{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchCurrentVersion": "!/^v?0/",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/osv-scanner.toml"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "matchStrings": [
        "GoVersionOverride = \"(?<currentValue>.+?)\""
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}