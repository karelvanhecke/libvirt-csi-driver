{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "security:gomodIndirectSecurityUpdates"
  ],
  "packageRules": [
    {
      "semanticCommitType": "fix",
      "matchDepTypes": [
        "indirect"
      ],
      "matchManagers": [
        "gomod"
      ]
    },
    {
      "groupName": "go",
      "matchDepNames": [
        "go",
        "go-security-level"
      ],
      "minimumGroupSize": 2
    },
    {
      "matchCurrentVersion": "!/^v?0/",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/osv-scanner.toml"
      ],
      "depNameTemplate": "go-security-level",
      "datasourceTemplate": "golang-version",
      "matchStrings": [
        "GoVersionOverride = \"(?<currentValue>.+?)\""
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}